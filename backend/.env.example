# ── Groq LLM API Keys ──────────────────────────────────────────────
# Comma-separated pool of keys. The system rotates automatically
# when any single key hits its rate limit.
GROQ_API_KEYS=gsk_key1_here,gsk_key2_here,gsk_key3_here

# Legacy single-key fallback (used if GROQ_API_KEYS is not set)
GROQ_API_KEY=gsk_your_single_key_here


# ── Sample Database Credentials (optional, for demo mode) ──────
# Supabase — prefer Session pooler on IPv4-only networks (typical on Windows):
#   Host: aws-0-<region>.pooler.supabase.com  (from Dashboard → Connect → Session mode)
#   Port: 5432
#   User: postgres.<project-ref>   (literal dot + ref, not only "postgres")
# Direct host db.<ref>.supabase.co is often IPv6-only; use pooler if you see DNS errors.
SUPABASE_HOST=aws-0-us-east-1.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
# Pooler session mode: use postgres.<project-ref> — get exact values from Dashboard → Connect
SUPABASE_USER=postgres.your-project-ref
SUPABASE_PASSWORD=your_supabase_password

TIDB_HOST=your-cluster.tidbcloud.com
TIDB_PORT=4000
TIDB_DATABASE=your_database
TIDB_USER=your_user
TIDB_PASSWORD=your_tidb_password

