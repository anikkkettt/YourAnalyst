# ══════════════════════════════════════════════════════════════════
# YourAnalyst — Environment Variables Template
# Copy this file to .env and fill in your own values.
# NEVER commit the .env file — it is gitignored.
# ══════════════════════════════════════════════════════════════════

# ── Groq LLM API Keys ───────────────────────────────────────────
# Comma-separated pool. The system auto-rotates on rate limits.
GROQ_API_KEYS=gsk_your_key_1,gsk_your_key_2

# ── Error Reporting (optional) ──────────────────────────────────
FEEDBACK_EMAIL=your_email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ── Sample Database Credentials (optional, for demo mode) ──────
# Supabase (PostgreSQL)
SUPABASE_HOST=your-project.supabase.co
SUPABASE_PORT=5432
SUPABASE_DATABASE=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_supabase_password

# TiDB Cloud (MySQL)
TIDB_HOST=your-cluster.tidbcloud.com
TIDB_PORT=4000
TIDB_DATABASE=your_database
TIDB_USER=your_user
TIDB_PASSWORD=your_tidb_password

# Turso (SQLite edge)
TURSO_HOST=your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_token

# ── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
